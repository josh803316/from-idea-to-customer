# =============================================================
# from-idea-to-customer — environment variables
# Copy this file to .env and fill in real values.
# Never commit .env to version control.
# =============================================================

# --- Database (Neon PostgreSQL) ------------------------------
# Get this from your Neon project dashboard.
DATABASE_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require

# --- API Server ---------------------------------------------
# Port the Elysia API listens on locally.
PORT=3000

# --- Web (Astro) --------------------------------------------
# PUBLIC_ prefix exposes the variable to client-side code.
# In production this should be your Fly.io app URL.
PUBLIC_API_URL=http://localhost:4322

# --- Neon Auth -----------------------------------------------
# Found in: Neon Console → your project → Auth → Configuration tab
NEON_AUTH_BASE_URL=https://ep-xxx.neonauth.us-east-1.aws.neon.tech/neondb/auth
# PUBLIC_ exposes this to browser (Astro/React islands)
PUBLIC_NEON_AUTH_URL=https://ep-xxx.neonauth.us-east-1.aws.neon.tech/neondb/auth

# --- OAuth (configure in Neon Console → Auth → OAuth) --------
# After adding Google/GitHub OAuth credentials in the Neon Console,
# no extra env vars are needed — Neon manages the secrets.

# --- AI Agent (Site Analysis Agent on home page) -------------
# Create an API key at https://api.you.com
# This is a SERVER-ONLY secret — no PUBLIC_ prefix.
YOU_API_KEY=

# --- Live Metrics (Lighthouse + Google Analytics) ------------
# 1. Google PageSpeed Insights API key (free):
#    https://developers.google.com/speed/docs/insights/v5/get-started
GOOGLE_PSI_API_KEY=

# 2. Google Analytics 4
#    a. Create a GA4 property at https://analytics.google.com
#    b. Add the Measurement ID (G-XXXXXXXXXX) below — PUBLIC so the
#       tracking script can be embedded on every page.
PUBLIC_GA4_MEASUREMENT_ID=G-XXXXXXXXXX
#    c. In Google Cloud Console, create a service account, enable the
#       "Google Analytics Data API", grant the service account "Viewer"
#       access in GA4 Admin → Account Access Management, then download
#       the JSON key and base64-encode it:
#         base64 -i service-account.json | tr -d '\n'
GA4_PROPERTY_ID=123456789
GA4_SERVICE_ACCOUNT_B64=
