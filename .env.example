# =============================================================
# from-idea-to-customer — environment variables
# Copy this file to .env and fill in real values.
# Never commit .env to version control.
# =============================================================

# --- Database (Neon PostgreSQL) ------------------------------
# Get this from your Neon project dashboard.
DATABASE_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require

# --- API Server ---------------------------------------------
# Port the Elysia API listens on locally.
PORT=3000

# --- Web (Astro) --------------------------------------------
# PUBLIC_ prefix exposes the variable to client-side code.
# In production this should be your Fly.io app URL.
PUBLIC_API_URL=http://localhost:4322

# --- Neon Auth -----------------------------------------------
# Found in: Neon Console → your project → Auth → Configuration tab
NEON_AUTH_BASE_URL=https://ep-xxx.neonauth.us-east-1.aws.neon.tech/neondb/auth
# PUBLIC_ exposes this to browser (Astro/React islands)
PUBLIC_NEON_AUTH_URL=https://ep-xxx.neonauth.us-east-1.aws.neon.tech/neondb/auth

# --- OAuth (configure in Neon Console → Auth → OAuth) --------
# After adding Google/GitHub OAuth credentials in the Neon Console,
# no extra env vars are needed — Neon manages the secrets.
