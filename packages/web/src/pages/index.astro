---
export const prerender = false;

import BaseLayout from '@/layouts/BaseLayout.astro';
import SiteAgent from '@/components/home/SiteAgent';
import PersonaHomePage from '@/components/home/PersonaHomePage';
import { FLAGS_COOKIE, parseOverrides, isFlagEnabled } from '@/lib/flags';

const overrides    = parseOverrides(Astro.cookies.get(FLAGS_COOKIE)?.value);
const showAgent    = isFlagEnabled(overrides, 'site-agent');
const showWaitlist = isFlagEnabled(overrides, 'waitlist-form');
---

<BaseLayout
  title="From Idea to Customer — AI-Native Development"
  description="The way we build software has changed forever. Explore the AI-native development era through the lens of your role — founder, engineer, designer, or any stakeholder in the stack."
>
  <!-- Hero ───────────────────────────────────────────────────────────────── -->
  <section class="py-20 text-center bg-gradient-to-b from-brand-50 to-white">
    <div class="max-w-3xl mx-auto px-4">
      <p class="text-xs font-semibold text-brand-600 uppercase tracking-widest mb-4">
        AI-Native Development
      </p>
      <h1 class="text-4xl sm:text-5xl font-extrabold text-gray-900 leading-tight mb-6">
        The Way We Build<br />Has Changed Forever
      </h1>
      <p class="text-lg text-gray-600 leading-relaxed mb-8 max-w-2xl mx-auto">
        We're living through the most significant shift in software creation since the internet.
        Select your persona below — the entire guide adapts to your language, your workflow,
        and your definition of done.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
        <a
          href="#ecosystem"
          class="inline-flex items-center gap-2 bg-brand-600 hover:bg-brand-700 text-white font-semibold px-6 py-3 rounded-xl transition-colors"
        >
          Explore the Ecosystem →
        </a>
        <a
          href="#waitlist"
          class="inline-flex items-center gap-2 border border-gray-300 hover:border-brand-400 text-gray-700 font-semibold px-6 py-3 rounded-xl transition-colors"
        >
          Join Waitlist
        </a>
      </div>
    </div>
  </section>

  {showAgent && <SiteAgent client:load />}

  <!-- Persona-aware main content ────────────────────────────────────────── -->
  <PersonaHomePage client:load showWaitlist={showWaitlist} />
</BaseLayout>
