---
// Pure Astro — zero JS, no hydration needed
---

<section class="py-16">
  <div class="max-w-5xl mx-auto px-4">
    <div class="text-center mb-12">
      <p class="text-xs font-medium text-gray-400 uppercase tracking-widest mb-3">The evolution</p>
      <h2 class="text-3xl font-bold text-gray-900">How We Got Here</h2>
    </div>

    <div class="grid md:grid-cols-3 gap-6">
      <!-- Waterfall -->
      <div class="bg-white border border-gray-200 rounded-2xl overflow-hidden shadow-sm">
        <div class="h-1.5 bg-red-400"></div>
        <div class="p-6">
          <div class="flex items-center justify-between mb-4">
            <div>
              <span class="text-2xl">🏗️</span>
              <h3 class="font-bold text-gray-900 mt-1">Waterfall</h3>
              <p class="text-xs text-gray-400">1990s–2000s</p>
            </div>
            <span class="text-xs font-semibold bg-red-100 text-red-700 px-2.5 py-1 rounded-full">
              6–18 months
            </span>
          </div>
          <ol class="space-y-2">
            {['Requirements', 'Architecture', 'Engineering', 'QA', 'Deploy'].map((step, i, arr) => (
              <li class="flex items-center gap-2 text-sm text-gray-600">
                <span class="w-5 h-5 rounded-full bg-red-100 text-red-700 flex items-center justify-center text-xs font-bold shrink-0">
                  {i + 1}
                </span>
                {step}
                {i < arr.length - 1 && <span class="text-gray-300 ml-auto">↓</span>}
              </li>
            ))}
          </ol>
          <p class="text-xs text-gray-400 mt-4 italic">
            Months of planning before a single line ships.
          </p>
        </div>
      </div>

      <!-- Agile -->
      <div class="bg-white border border-gray-200 rounded-2xl overflow-hidden shadow-sm">
        <div class="h-1.5 bg-amber-400"></div>
        <div class="p-6">
          <div class="flex items-center justify-between mb-4">
            <div>
              <span class="text-2xl">🔄</span>
              <h3 class="font-bold text-gray-900 mt-1">Agile</h3>
              <p class="text-xs text-gray-400">2010s</p>
            </div>
            <span class="text-xs font-semibold bg-amber-100 text-amber-700 px-2.5 py-1 rounded-full">
              4–8 weeks
            </span>
          </div>
          <ol class="space-y-2">
            {['Backlog', 'Standups', 'Sprints', 'Review', 'Release'].map((step, i, arr) => (
              <li class="flex items-center gap-2 text-sm text-gray-600">
                <span class="w-5 h-5 rounded-full bg-amber-100 text-amber-700 flex items-center justify-center text-xs font-bold shrink-0">
                  {i + 1}
                </span>
                {step}
                {i < arr.length - 1 && <span class="text-gray-300 ml-auto">↓</span>}
              </li>
            ))}
          </ol>
          <p class="text-xs text-gray-400 mt-4 italic">
            Faster cycles, but still human-paced.
          </p>
        </div>
      </div>

      <!-- AI-Native -->
      <div class="bg-white border border-gray-200 rounded-2xl overflow-hidden shadow-sm ring-2 ring-green-400 ring-offset-2">
        <div class="h-1.5 bg-green-400"></div>
        <div class="p-6">
          <div class="flex items-center justify-between mb-4">
            <div>
              <span class="text-2xl">🤖</span>
              <h3 class="font-bold text-gray-900 mt-1">AI-Native</h3>
              <p class="text-xs text-gray-400">2024+</p>
            </div>
            <span class="text-xs font-semibold bg-green-100 text-green-700 px-2.5 py-1 rounded-full">
              Hours to days
            </span>
          </div>
          <ol class="space-y-2">
            {['Idea', 'AI writes code', 'Human reviews', 'Ship'].map((step, i, arr) => (
              <li class="flex items-center gap-2 text-sm text-gray-600">
                <span class="w-5 h-5 rounded-full bg-green-100 text-green-700 flex items-center justify-center text-xs font-bold shrink-0">
                  {i + 1}
                </span>
                {step}
                {i < arr.length - 1 && <span class="text-gray-300 ml-auto">↓</span>}
              </li>
            ))}
          </ol>
          <p class="text-xs text-gray-400 mt-4 italic">
            AI handles scaffolding. Humans focus on judgment.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
