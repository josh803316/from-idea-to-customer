---
interface Props {
  headlineVariant?: 'control' | 'outcome' | 'direct';
  ctaVariant?: 'control' | 'action' | 'curiosity';
}

const { headlineVariant = 'control', ctaVariant = 'control' } = Astro.props;

const headlines: Record<string, { main: string; accent: string }> = {
  control: { main: 'You can manage it.', accent: 'Or it will manage you.' },
  outcome: { main: 'Stop executing tasks.', accent: 'Start owning outcomes.' },
  direct: { main: 'From junior engineer', accent: 'to system owner.' },
};

const ctaLabels: Record<string, string> = {
  control: 'Start with the Checkerboard',
  action: 'Start Learning Free',
  curiosity: 'Show Me the Roadmap',
};

const headline = headlines[headlineVariant] ?? headlines.control;
const ctaLabel = ctaLabels[ctaVariant] ?? ctaLabels.control;

const examples = [
  {
    icon: '☕',
    place: 'Coffee Shop',
    field: 'Menu depth, staff roles, the line, the regulars, the margin per cup.',
    insight: 'The barista who owns the morning rush thinks like an owner. The one who just makes drinks gets managed by it.',
  },
  {
    icon: '🛒',
    place: 'Amazon',
    field: 'Catalog × sellers × logistics × data × customer trust.',
    insight: 'Every team touches a different square. The leaders who thrive are the ones who see the whole board.',
  },
  {
    icon: '🍦',
    place: 'Baskin-Robbins',
    field: '32 flavors = options × constraints × customer psychology.',
    insight: 'More choice is not always better. Managing the field means knowing when to add a flavor and when to retire one.',
  },
  {
    icon: '💻',
    place: 'Your Tech Stack',
    field: 'APIs, databases, UI, DevOps, users, budgets, deadlines, technical debt.',
    insight: 'Junior engineers inherit the field. Senior engineers shape it. The best ones own it — before it owns them.',
  },
];

const hats = [
  { label: 'Product', icon: '📋', desc: 'What do we build?', color: 'bg-blue-50 border-blue-200 text-blue-800', pos: 'top-[8%] left-[5%]' },
  { label: 'CTO', icon: '⚙️', desc: 'How do we build it?', color: 'bg-gray-50 border-gray-300 text-gray-800', pos: 'top-[8%] right-[5%]' },
  { label: 'Sales', icon: '🤝', desc: 'Who buys it?', color: 'bg-green-50 border-green-200 text-green-800', pos: 'bottom-[10%] left-[5%]' },
  { label: 'Marketing', icon: '📣', desc: 'How do they find us?', color: 'bg-amber-50 border-amber-200 text-amber-800', pos: 'bottom-[10%] right-[5%]' },
  { label: 'The User', icon: '👤', desc: 'What do they need?', color: 'bg-purple-50 border-purple-200 text-purple-800', pos: 'top-[42%] left-[50%] -translate-x-1/2 -translate-y-1/2' },
];
---

<!-- ── Intro ─────────────────────────────────────────────── -->
<section class="pt-20 pb-10 text-center">
  <div class="inline-flex items-center gap-2 bg-brand-50 text-brand-700 text-sm font-medium px-4 py-2 rounded-full mb-8">
    <span aria-hidden="true">♟</span>
    <span>Performing in a Multidimensional Field</span>
  </div>

  <h1 class="text-5xl sm:text-6xl font-bold text-gray-900 leading-tight max-w-3xl mx-auto mb-6">
    {headline.main}<br />
    <span class="text-brand-600">{headline.accent}</span>
  </h1>

  <p class="text-xl text-gray-600 max-w-2xl mx-auto mb-4">
    Every role — in every industry — operates inside a multidimensional field.
    Competing constraints, overlapping responsibilities, trade-offs with no clean answer.
  </p>
  <p class="text-lg text-gray-500 max-w-xl mx-auto mb-12">
    It's everywhere. The leaders who succeed don't escape the complexity.
    They learn to own it.
  </p>
</section>

<!-- ── It's everywhere ───────────────────────────────────── -->
<section class="pb-16">
  <p class="text-center text-sm font-medium text-gray-400 uppercase tracking-widest mb-8">
    It&rsquo;s everywhere&hellip;
  </p>
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
    {examples.map((ex) => (
      <div class="bg-white border border-gray-100 rounded-xl p-5 shadow-sm hover:shadow-md transition-shadow">
        <div class="text-3xl mb-3">{ex.icon}</div>
        <h3 class="font-semibold text-gray-900 mb-1">{ex.place}</h3>
        <p class="text-xs text-gray-500 mb-3 leading-relaxed">{ex.field}</p>
        <p class="text-sm text-gray-700 leading-relaxed border-t border-gray-50 pt-3">{ex.insight}</p>
      </div>
    ))}
  </div>
</section>

<!-- ── Chessboard Visual ─────────────────────────────────── -->
<section class="pb-16">
  <p class="text-center text-sm font-medium text-gray-400 uppercase tracking-widest mb-6">
    &hellip;and in your tech product lifecycle and stack
  </p>

  <div
    class="relative rounded-2xl overflow-hidden border border-gray-200 shadow-lg"
    style="min-height: 380px;"
  >
    <!-- Checkerboard background -->
    <div
      class="absolute inset-0"
      style="background-color: #f8fafc; background-image: linear-gradient(45deg, #e2e8f0 25%, transparent 25%), linear-gradient(-45deg, #e2e8f0 25%, transparent 25%), linear-gradient(45deg, transparent 75%, #e2e8f0 75%), linear-gradient(-45deg, transparent 75%, #e2e8f0 75%); background-size: 48px 48px; background-position: 0 0, 0 24px, 24px -24px, -24px 0px;"
      aria-hidden="true"
    />

    <!-- Subtle vignette overlay -->
    <div
      class="absolute inset-0"
      style="background: radial-gradient(ellipse at center, transparent 40%, rgba(248,250,252,0.7) 100%);"
      aria-hidden="true"
    />

    <!-- Hat cards -->
    {hats.map((hat) => (
      <div class={`absolute ${hat.pos} z-10`}>
        <div class={`border rounded-xl px-4 py-3 shadow-md backdrop-blur-sm ${hat.color} text-center min-w-[110px]`}>
          <div class="text-2xl mb-1">{hat.icon}</div>
          <div class="font-semibold text-sm leading-tight">{hat.label}</div>
          <div class="text-xs opacity-70 mt-0.5">{hat.desc}</div>
        </div>
      </div>
    ))}

    <!-- Centre value statement -->
    <div class="relative z-20 flex items-center justify-center" style="min-height: 380px;">
      <div class="text-center bg-white/90 backdrop-blur-sm border border-gray-200 rounded-2xl px-8 py-6 shadow-xl max-w-xs mx-4">
        <div class="text-4xl mb-3">♟</div>
        <p class="text-lg font-bold text-gray-900 leading-snug mb-1">
          Own the board.
        </p>
        <p class="text-sm text-gray-500">
          The journey from engineer to owner isn&rsquo;t about seniority.
          It&rsquo;s about learning to see &mdash; and manage &mdash; the whole field.
        </p>
      </div>
    </div>
  </div>

  <!-- Stack strip -->
  <p class="text-center text-xs text-gray-400 mt-5 leading-relaxed">
    The field is the same whether you&rsquo;re on&nbsp;
    <span class="text-gray-500">Vercel</span> &middot;
    <span class="text-gray-500">Cloudflare Workers</span> &middot;
    <span class="text-gray-500">AWS</span> &middot;
    <span class="text-gray-500">GCP</span> &middot;
    <span class="text-gray-500">Azure</span> &middot;
    <span class="text-gray-500">Fly.io</span> &middot;
    <span class="text-gray-500">Railway</span> &middot;
    <span class="text-gray-500">Render</span> &middot;
    <span class="text-gray-500">Supabase</span> &middot;
    <span class="text-gray-500">Neon</span> &middot;
    <span class="text-gray-500">PlanetScale</span> &middot;
    <span class="text-gray-500">Heroku</span>
    &nbsp;&mdash; the trade-offs just wear different names.
  </p>
</section>

<!-- ── Core value + CTAs ─────────────────────────────────── -->
<section class="pb-20 text-center">
  <blockquote class="text-2xl sm:text-3xl font-bold text-gray-900 max-w-2xl mx-auto mb-3 leading-tight">
    &ldquo;You can manage it,<br class="hidden sm:block" /> or it will manage you.&rdquo;
  </blockquote>
  <p class="text-gray-500 mb-10 text-lg">
    This curriculum teaches you how to own your square &mdash; then the whole board.
  </p>

  <div class="flex flex-col sm:flex-row gap-4 justify-center">
    <a
      href="/courses"
      class="bg-brand-600 text-white px-8 py-4 rounded-xl font-semibold text-lg hover:bg-brand-700 transition-colors"
    >
      {ctaLabel}
    </a>
    <a
      href="/waitlist"
      class="border border-gray-200 text-gray-700 px-8 py-4 rounded-xl font-semibold text-lg hover:border-gray-400 transition-colors"
    >
      Join the waitlist
    </a>
  </div>
</section>
