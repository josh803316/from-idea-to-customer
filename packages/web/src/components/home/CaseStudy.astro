---
// CaseStudy.astro
// Framing for the live metrics section. The actual numbers come from LiveMetrics.tsx.

const monetisationGoal = {
  model: 'Ad Revenue (CPM)',
  targets: [
    { label: 'Monthly unique visitors', value: '50K', note: 'to hit $500/mo at $10 CPM' },
    { label: 'Avg pages per session', value: '3.5+', note: 'target — currently ~1.8' },
    { label: 'Session duration target', value: '>5 min', note: 'signals quality to ad networks' },
    { label: 'Organic search share', value: '70%+', note: 'goal — paid is not profitable at our scale' },
  ],
};
---

<section class="py-20 border-t border-gray-100">
  <!-- Header -->
  <div class="text-center mb-16">
    <div class="inline-flex items-center gap-2 bg-brand-50 text-brand-700 text-sm font-medium px-4 py-2 rounded-full mb-6">
      <span aria-hidden="true">&#128202;</span>
      <span>Live case study &mdash; this site, right now</span>
    </div>
    <h2 class="text-4xl font-bold text-gray-900 mb-4">
      The site you&rsquo;re reading is the example.
    </h2>
    <p class="text-xl text-gray-600 max-w-3xl mx-auto mb-4">
      We&rsquo;re building <em>From Idea to Customer</em> to monetise via advertising. That means
      traffic volume &times; quality = revenue. Every engineering and content decision we make
      is measured against that goal.
    </p>
    <p class="text-gray-500 max-w-2xl mx-auto">
      Below are the real numbers — live Lighthouse scores and Google Analytics data — for
      this site right now. Use the AI agent at the bottom to interrogate any metric,
      propose an improvement, or challenge our assumptions.
    </p>
  </div>

  <!-- Monetisation goal banner -->
  <div class="bg-gray-900 text-white rounded-2xl p-8 mb-10">
    <div class="flex flex-col lg:flex-row lg:items-center gap-6">
      <div class="flex-1">
        <p class="text-brand-400 text-sm font-medium mb-1 uppercase tracking-wider">Business model</p>
        <h3 class="text-2xl font-bold mb-2">{monetisationGoal.model}</h3>
        <p class="text-gray-400">
          Revenue = CPM rate &times; (monthly impressions / 1000).
          CPM improves with session quality; impressions grow with unique visitors.
          Both are engineering and content problems.
        </p>
      </div>
      <div class="grid grid-cols-2 gap-4 lg:grid-cols-4">
        {monetisationGoal.targets.map((t) => (
          <div class="bg-white/10 rounded-xl p-4 text-center">
            <div class="text-2xl font-bold text-white mb-1">{t.value}</div>
            <div class="text-xs text-gray-400 leading-tight">{t.label}</div>
            <div class="text-xs text-brand-400 mt-1 leading-tight">{t.note}</div>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- LiveMetrics island injected from index.astro -->
  <slot />

  <!-- Teaching callout -->
  <div class="bg-brand-50 border border-brand-100 rounded-2xl p-8 text-center mt-10">
    <h3 class="text-xl font-bold text-gray-900 mb-3">
      These numbers are the curriculum.
    </h3>
    <p class="text-gray-600 max-w-2xl mx-auto mb-4">
      Every score above is a real trade-off, a real constraint, or a real opportunity.
      The courses teach you to reason about each one — as a PM (what&rsquo;s worth building?),
      a CTO (what&rsquo;s the cost?), and a marketer (what moves the needle?).
    </p>
    <p class="text-sm text-gray-500">
      Lighthouse runs against the live production URL. Analytics reflects the last 30 days.
      Ask the agent below to explain any number or propose an improvement.
    </p>
  </div>
</section>
