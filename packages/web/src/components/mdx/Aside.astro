---
interface Props {
  type?: 'insight' | 'warning' | 'tip';
}

const { type = 'insight' } = Astro.props;

const styles = {
  insight: 'bg-blue-50 border-blue-400 text-blue-900',
  warning: 'bg-amber-50 border-amber-400 text-amber-900',
  tip: 'bg-green-50 border-green-400 text-green-900',
};

const icons = {
  insight: '💡',
  warning: '⚠️',
  tip: '✅',
};
---

<aside class={`my-6 border-l-4 rounded-r-lg p-4 ${styles[type]}`}>
  <span class="mr-2" aria-hidden="true">{icons[type]}</span>
  <slot />
</aside>
